# API Configuration (ajusta el puerto según tu backend)
VITE_API_URL=https://localhost:7191/api

# Environment
VITE_ENV=development

# App Configuration
VITE_APP_NAME=RegularizadorPolizas
VITE_APP_VERSION=1.0.0

# JWT Configuration (opcional para debugging)
VITE_JWT_ENABLE_DECODE=true

# Optional: Azure Static Web Apps configuration
VITE_AZURE_CLIENT_ID=your-azure-client-id
VITE_AZURE_TENANT_ID=your-azure-tenant-id