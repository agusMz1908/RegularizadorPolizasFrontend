# API Configuration
VITE_API_URL=https://localhost:7191/api

# Endpoints configurables
VITE_CLIENTES_ENDPOINT=Clients
VITE_POLIZAS_ENDPOINT=Polizas

# Parámetros de paginación por defecto
VITE_DEFAULT_PAGE_SIZE=1000
VITE_POLIZAS_PAGE_SIZE=50

# Azure Document Intelligence
VITE_AZURE_DOC_ENDPOINT=https://extraccion-polizas.cognitiveservices.azure.com/

# Environment
VITE_ENV=production

# App Configuration
VITE_APP_NAME=RegularizadorPolizas
VITE_APP_VERSION=1.0.0

# Production flags
VITE_ENABLE_MOCK_DATA=false
VITE_ENABLE_DEBUG_LOGS=true

# JWT Configuration
VITE_JWT_ENABLE_DECODE=true

# API Timeouts
VITE_VELNEO_TIMEOUT=120000