# ================================
# API CONFIGURATION
# ================================
VITE_API_URL=https://localhost:7191/api

VITE_CLIENTES_ENDPOINT=clientes
VITE_POLIZAS_ENDPOINT=polizas

# ================================
# PAGINACIÓN OPTIMIZADA
# ================================
VITE_DEFAULT_PAGE_SIZE=25
VITE_CLIENTES_PAGE_SIZE=25
VITE_POLIZAS_PAGE_SIZE=25
VITE_POLIZAS_BY_CLIENT_PAGE_SIZE=10

# ================================
# AZURE DOCUMENT INTELLIGENCE
# ================================
VITE_AZURE_DOC_ENDPOINT=https://extraccion-polizas.cognitiveservices.azure.com/

# ================================
# ENVIRONMENT CONFIG
# ================================
VITE_ENV=development
VITE_NODE_ENV=development

# ================================
# APP CONFIGURATION
# ================================
VITE_APP_NAME=RegularizadorPolizas
VITE_APP_VERSION=2.0.0
VITE_APP_DESCRIPTION=Sistema de gestión de pólizas con API optimizada

# ================================
# FEATURE FLAGS
# ================================
VITE_ENABLE_MOCK_DATA=false
VITE_ENABLE_DEBUG_LOGS=true
VITE_ENABLE_REAL_PAGINATION=true
VITE_ENABLE_CLIENT_SIDE_CACHE=false

# ================================
# AUTHENTICATION
# ================================
VITE_JWT_ENABLE_DECODE=true
VITE_JWT_STORAGE_KEY=regularizador_token
VITE_JWT_USER_KEY=regularizador_user

# ================================
# API TIMEOUTS & PERFORMANCE
# ================================
VITE_API_TIMEOUT=30000
VITE_CLIENT_REQUEST_TIMEOUT=15000
VITE_POLIZA_REQUEST_TIMEOUT=20000

# ================================
# ENDPOINTS ESPECÍFICOS (Nuevos)
# ================================
VITE_CLIENTES_BASE_URL=/api/clientes
VITE_POLIZAS_BASE_URL=/api/polizas
VITE_AUTH_BASE_URL=/api/auth

VITE_CLIENTES_PAGINATED_ENDPOINT=clientes
VITE_CLIENTES_ALL_ENDPOINT=clientes/all
VITE_POLIZAS_PAGINATED_ENDPOINT=polizas
VITE_POLIZAS_ALL_ENDPOINT=polizas/all
VITE_POLIZAS_BY_CLIENT_ENDPOINT=polizas/cliente

# ================================
# UI CONFIGURATION
# ================================
VITE_ITEMS_PER_PAGE_OPTIONS=10,25,50,100
VITE_DEFAULT_SORT_ORDER=asc
VITE_DEFAULT_SORT_FIELD=nombre

# ================================
# CACHE CONFIGURATION
# ================================
VITE_CACHE_TTL=300000
VITE_CACHE_MAX_SIZE=100

# ================================
# DEVELOPMENT FLAGS
# ================================
VITE_SHOW_API_CALLS=true
VITE_SHOW_PERFORMANCE_METRICS=true
VITE_ENABLE_REDUX_DEVTOOLS=true