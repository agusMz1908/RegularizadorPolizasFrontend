# API Configuration (ajusta el puerto según tu backend)
VITE_API_URL=https://localhost:7191/api

# Azure Document Intelligence (opcional - configurar cuando tengas el servicio)
VITE_AZURE_DOC_ENDPOINT=

# Velneo Integration (opcional - configurar cuando esté listo)
VITE_VELNEO_ENDPOINT=

# Environment
VITE_ENV=development

# App Configuration
VITE_APP_NAME=RegularizadorPolizas
VITE_APP_VERSION=1.0.0

# Development flags
VITE_ENABLE_MOCK_DATA=true
VITE_ENABLE_DEBUG_LOGS=true

# JWT Configuration (opcional para debugging)
VITE_JWT_ENABLE_DECODE=true

# Optional: Azure Static Web Apps configuration (para producción)
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=